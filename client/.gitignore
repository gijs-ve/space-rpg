# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm
.pnpm-store/

# =============================================================================
# Testing
# =============================================================================
/coverage
.nyc_output/
*.lcov
.jest-cache/

# =============================================================================
# Next.js
# =============================================================================
/.next/
/out/

# =============================================================================
# Production build
# =============================================================================
/build
/dist

# =============================================================================
# Environment variables
# =============================================================================
.env
.env.*
!.env.example
!.env.*.example

# =============================================================================
# Vercel
# =============================================================================
.vercel

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo
next-env.d.ts
*.d.ts.map

# =============================================================================
# Debug / Logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log
*.log.*

# =============================================================================
# OS files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Editors & IDEs
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.iml
*.swp
*.swo
*~

# =============================================================================
# Certificates & secrets
# =============================================================================
*.pem
*.key
*.cert
*.crt

# =============================================================================
# Misc
# =============================================================================
.turbo/
.cache/
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig
*.rej
