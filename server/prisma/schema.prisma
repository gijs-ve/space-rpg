// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Player ───────────────────────────────────────────────────────────────────
model Player {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hero   Hero?
  cities City[]
  jobs   Job[]
}

// ─── Hero ─────────────────────────────────────────────────────────────────────
model Hero {
  id              String   @id @default(cuid())
  playerId        String   @unique
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  level           Int      @default(1)
  xp              Int      @default(0)
  energy          Int      @default(100)
  maxEnergy       Int      @default(100)
  lastEnergyRegen DateTime @default(now())

  // JSON: { combat: 0, endurance: 0, gathering: 0, leadership: 0, tactics: 0 }
  skillLevels Json @default("{\"combat\":0,\"endurance\":0,\"gathering\":0,\"leadership\":0,\"tactics\":0}")
  // JSON: same shape but stores accumulated skill XP
  skillXp     Json @default("{\"combat\":0,\"endurance\":0,\"gathering\":0,\"leadership\":0,\"tactics\":0}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── City ─────────────────────────────────────────────────────────────────────
model City {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  name  String
  x     Int
  y     Int
  civId String @default("terran")

  // JSON: { rations: 500, water: 500, ore: 300, alloys: 100, fuel: 100, iridium: 20 }
  resources  Json @default("{\"rations\":500,\"water\":500,\"ore\":300,\"alloys\":100,\"fuel\":100,\"iridium\":20}")
  // JSON: { rations: 1000, water: 1000, ore: 1000, alloys: 1000, fuel: 1000, iridium: 1000 }
  storageCap Json @default("{\"rations\":1000,\"water\":1000,\"ore\":1000,\"alloys\":1000,\"fuel\":1000,\"iridium\":1000}")

  // JSON array: [{ slotIndex: 0, buildingId: "town_hall", level: 1 }, ...]
  buildings Json @default("[]")

  // JSON: { marine: 0, marksman: 0, scout_bike: 0, heavy_mech: 0 }
  troops Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs     Job[]
  mapTile  MapTile?

  @@unique([x, y])
}

// ─── Job ──────────────────────────────────────────────────────────────────────
model Job {
  id       String @id @default(cuid())
  type     String // 'adventure' | 'construction' | 'training'
  playerId String
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cityId   String?
  city     City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)

  // JSON: AdventureJobMeta | ConstructionJobMeta | TrainingJobMeta
  metadata  Json
  startedAt DateTime @default(now())
  endsAt    DateTime
  completed Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completed, endsAt])
  @@index([playerId, completed])
}

// ─── MapTile ──────────────────────────────────────────────────────────────────
model MapTile {
  x      Int
  y      Int
  type   String // TileType

  cityId String? @unique
  city   City?   @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@id([x, y])
}
