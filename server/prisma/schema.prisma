// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Player ───────────────────────────────────────────────────────────────────
model Player {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hero   Hero?
  cities City[]
  jobs   Job[]
  reports ActivityReport[]
}

// ─── Hero ─────────────────────────────────────────────────────────────────────
model Hero {
  id              String   @id @default(cuid())
  playerId        String   @unique
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  level           Int      @default(1)
  xp              Int      @default(0)
  health          Int      @default(100)
  maxHealth       Int      @default(100)
  lastHealthRegen DateTime @default(now())
  energy          Int      @default(100)
  maxEnergy       Int      @default(100)
  lastEnergyRegen DateTime @default(now())

  // JSON: { combat: 1, endurance: 1, gathering: 1, leadership: 1, tactics: 1 }
  skillLevels Json @default("{\"combat\":1,\"endurance\":1,\"gathering\":1,\"leadership\":1,\"tactics\":1}")
  // JSON: same shape but stores accumulated skill XP
  skillXp     Json @default("{\"combat\":0,\"endurance\":0,\"gathering\":0,\"leadership\":0,\"tactics\":0}")

  // Home city (nullable — null until player founds their first city)
  homeCityId String?  @unique
  homeCity   City?   @relation("HeroHomeCity", fields: [homeCityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemInstance[]
}

// ─── City ─────────────────────────────────────────────────────────────────────
model City {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  name  String
  x     Int
  y     Int
  civId String @default("terran")

  // JSON: { rations: 500, water: 500, ore: 300, alloys: 100, fuel: 100, iridium: 20 }
  resources  Json @default("{\"rations\":500,\"water\":500,\"ore\":300,\"alloys\":100,\"fuel\":100,\"iridium\":20}")
  // JSON: { rations: 1000, water: 1000, ore: 1000, alloys: 1000, fuel: 1000, iridium: 1000 }
  storageCap Json @default("{\"rations\":1000,\"water\":1000,\"ore\":1000,\"alloys\":1000,\"fuel\":1000,\"iridium\":1000}")

  // JSON array: [{ slotIndex: 0, buildingId: "town_hall", level: 1 }, ...]
  buildings Json @default("[]")

  // JSON: { marine: 0, marksman: 0, scout_bike: 0, heavy_mech: 0 }
  troops Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs     Job[]
  mapTile  MapTile?
  items    ItemInstance[]
  heroHome Hero?          @relation("HeroHomeCity")
  marketListings MarketListing[]
  craftingSlots  CraftingSlot[]

  @@unique([x, y])
}

// ─── Job ──────────────────────────────────────────────────────────────────────
model Job {
  id       String @id @default(cuid())
  type     String // 'adventure' | 'construction' | 'training' | 'crafting'
  playerId String
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cityId   String?
  city     City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)

  // JSON: AdventureJobMeta | ConstructionJobMeta | TrainingJobMeta | CraftingJobMeta
  metadata  Json
  startedAt DateTime @default(now())
  endsAt    DateTime
  completed Boolean  @default(false)

  craftingSlot CraftingSlot? @relation("CraftingJob")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completed, endsAt])
  @@index([playerId, completed])
}

// ─── MapTile ──────────────────────────────────────────────────────────────────
model MapTile {
  x      Int
  y      Int
  type   String // TileType

  cityId String? @unique
  city   City?   @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@id([x, y])
}
// ─── ItemInstance ───────────────────────────────────────────────────────────────────
enum ItemLocation {
  hero_inventory
  hero_equipped
  base_armory
  base_building_equip
  activity_report
  market_listing
}

model ItemInstance {
  id        String       @id @default(cuid())
  itemDefId String
  rotated   Boolean      @default(false)

  // Grid position (null when equipped or pending in report)
  gridX Int?
  gridY Int?

  // Owner references
  heroId String?
  hero   Hero?   @relation(fields: [heroId], references: [id], onDelete: Cascade)
  cityId String?
  city   City?   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  location  ItemLocation

  // Hero equip slot (e.g. 'weapon', 'helmet', 'body', 'legs')
  equipSlot String?

  // Building equip slot
  buildingSlotIndex Int?
  buildingEquipSlot String? // 'slot_a' | 'slot_b'

  // Activity report pending claim
  reportId String?
  report   ActivityReport? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Black-market voucher — references the listing this voucher backs
  marketListingId String?
  marketListing   MarketListing? @relation("VoucherItems", fields: [marketListingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([heroId, location])
  @@index([cityId, location])
  @@index([reportId])
  @@index([marketListingId])
}

// ─── ActivityReport ──────────────────────────────────────────────────────────────────
model ActivityReport {
  id           String    @id @default(cuid())
  playerId     String
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  activityType String
  xpAwarded       Int
  skillXpAwarded  Json      @default("{}")
  resources       Json      // Partial<ResourceMap>
  damageTaken     Int       @default(0)
  completedAt     DateTime  @default(now())
  dismissed        Boolean   @default(false)
  viewed           Boolean   @default(false)
  resourcesClaimed Boolean   @default(false)

  items ItemInstance[]

  @@index([playerId, dismissed])
}
// ─── MarketListing ────────────────────────────────────────────────────────────────────────────
// type: 'sell' | 'buy'
// kind: 'item' | 'resource'
// status: 'active' | 'completed' | 'cancelled'
model MarketListing {
  id     String @id @default(cuid())
  type   String // 'sell' | 'buy'
  kind   String // 'item' | 'resource'
  status String @default("active") // 'active' | 'completed' | 'cancelled'

  // The base that owns this listing
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  // For item listings: which item def is being sold/sought
  itemDefId      String?
  // For sell-item listings: the specific escrowed instance
  itemInstanceId String? @unique

  // For resource listings
  resourceType   String? // ResourceType
  resourceAmount Int?

  // Price in iridium (always integers)
  priceIridium Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Voucher item(s) linked to this listing (normally 0 or 1)
  voucherItems ItemInstance[] @relation("VoucherItems")

  @@index([status, kind, type])
  @@index([cityId])
  @@index([itemDefId, status])
  @@index([resourceType, status])
}

// ─── Vendor ────────────────────────────────────────────────────────────────────────────────
model Vendor {
  id          String        @id
  name        String
  description String

  stock VendorStock[]
}

// Stock entry for a vendor: one row per (vendor, itemDefId) pair
model VendorStock {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  itemDefId              String
  currentStock           Int
  maxStock               Int
  sellPrice              Int // vendor sells at this price (player buys)
  buyPrice               Int // vendor buys at this price (player sells)
  restockIntervalMinutes Int
  lastRestockedAt        DateTime @default(now())

  @@unique([vendorId, itemDefId])
  @@index([vendorId])
}

// ─── CraftingSlot ──────────────────────────────────────────────────────────────────────────
// One row per active crafting station (city + building slot + recipe).
// inputQueueCount  = items consumed and waiting to be processed
// outputCount      = completed outputs ready to collect
// processingJob    = active Job row (type 'crafting') for the current run
model CraftingSlot {
  id                String  @id @default(cuid())
  cityId            String
  city              City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  buildingSlotIndex Int
  recipeId          String

  inputQueueCount   Int     @default(0)
  outputCount       Int     @default(0)

  processingJobId   String? @unique
  processingJob     Job?    @relation("CraftingJob", fields: [processingJobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, buildingSlotIndex, recipeId])
  @@index([cityId])
}